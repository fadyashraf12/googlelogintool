modules = ["python-3.12"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["gitFull", "playwright-driver"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "vnc"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "Xvfb :99 -screen 0 1280x900x24 & sleep 1 && DISPLAY=:99 PLAYWRIGHT_BROWSERS_PATH=/nix/store/kcvsxrmgwp3ffz5jijyy7wn9fcsjl4hz-playwright-browsers-1.55.0-with-cjk python main.py"

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "Xvfb :99 -screen 0 1280x900x24 & sleep 1 && DISPLAY=:99 python main.py"]
